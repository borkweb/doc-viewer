  "include": ["src/renderer/src", "src/shared", "src/main/pipeline/parse.ts", "tests/render.test.ts", "tests/addProjectModal.test.ts", "tests/branchSwitcher.test.ts", "tests/manageProjects.test.ts", "tests/topBarManage.test.ts"]
}
